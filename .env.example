APP_NAME=quotes-social-app-backend
NODE_ENV=development
LOG_LEVEL=debug
PORT=5000
API_PREFIX=/api/v1
TRUST_PROXY=false
SHUTDOWN_TIMEOUT_MS=10000
MONGODB_URI=mongodb://127.0.0.1:27017/quotes-social-app
CORS_ORIGIN=http://localhost:3000
JWT_SECRET=replace-with-a-random-secret-at-least-32-characters
JWT_EXPIRES_IN=15m
JWT_ISSUER=quotes-social-app
JWT_AUDIENCE=quotes-social-users
BCRYPT_SALT_ROUNDS=12
RATE_LIMIT_WINDOW_MS=900000
RATE_LIMIT_MAX_REQUESTS=100
AUTH_RATE_LIMIT_WINDOW_MS=900000
AUTH_RATE_LIMIT_MAX_REQUESTS=10
ADMIN_NOTIFICATION_RATE_LIMIT_WINDOW_MS=60000
ADMIN_NOTIFICATION_RATE_LIMIT_MAX_REQUESTS=20
GOOGLE_CLIENT_IDS=
ADMIN_NAME=
ADMIN_EMAIL=
ADMIN_PASSWORD=
FCM_ENABLED=false
FIREBASE_USE_APPLICATION_DEFAULT=false
FIREBASE_PROJECT_ID=
FIREBASE_CLIENT_EMAIL=
FIREBASE_PRIVATE_KEY=
FCM_GLOBAL_TOPIC=quotes-social-all-users
FCM_AUTO_SUBSCRIBE_GLOBAL_TOPIC=true
